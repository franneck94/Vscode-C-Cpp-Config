{
    "C_Cpp_Config.cCompilerPath": "clangg",
    "C_Cpp_Config.cppCompilerPath": "clangg++",
    "C_Cpp_Config.debuggerPath": "lldb",
    "C_Cpp_Config.makePath": "make",
    // Editor settings
    "editor.tabSize": 4,
    "editor.rulers": [80, 120],
    "editor.renderWhitespace": "trailing",
    "editor.suggestSelection": "first",
    "diffEditor.ignoreTrimWhitespace": false,
    // Explorer settings
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "explorer.compactFolders": false,
    // Files settings
    "files.autoSave": "onFocusChange",
    "files.associations": {
        ".clang*": "yaml"
    },
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    // Workbench settings
    "workbench.startupEditor": "newUntitledFile",
    "workbench.editorAssociations": {
        "*.md": "vscode.markdown.preview.editor",
        "*.svg": "svgPreviewer.customEditor"
    },
    // Git settings
    "git.enableSmartCommit": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    // C/C++
    "C_Cpp.clang_format_sortIncludes": true,
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.cStandard": "c99",
    "C_Cpp.formatting": "clangFormat",
    // Cmake settings
    "cmake.configureOnOpen": false,
    "cmake.autoSelectActiveFolder": false,
    "cmake.configureOnEdit": false,
    // C/C++ Doxygen Docstrings
    "doxdocgen.file.fileTemplate": "@file {name}",
    "doxdocgen.cpp.tparamTemplate": "@tparam {param} ",
    "doxdocgen.generic.briefTemplate": "@brief {text}",
    "doxdocgen.generic.boolReturnsTrueFalse": false,
    "doxdocgen.generic.paramTemplate": "@param {param} ",
    "doxdocgen.generic.returnTemplate": "@return",
    "doxdocgen.generic.includeTypeAtReturn": false,
    // IntelliSense AI Extension
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    // Formatting tools
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.tabWidth": 4,
    "[c]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[cpp]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[markdown]": {
        "files.trimTrailingWhitespace": false,
        "editor.formatOnSave": false,
        "editor.defaultFormatter": "yzhang.markdown-all-in-one",
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 120
    },
    "[plaintext]": {
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 120
    },
    "Workspace_Formatter.includePattern": [
        "*.c",
        "*.h",
        "*.cc",
        "*.hh",
        "*.hpp"
    ],
    "Workspace_Formatter.excludePattern": ["**/build", "**/.*", "**/.vscode"],
    // Other extensions
    "codesnap.showWindowControls": false,
    "codesnap.shutterAction": "copy",
    "svg.preview.autoOpen": true,
    "errorLens.delay": 1000,
    "errorLens.enabledDiagnosticLevels": ["error", "warning"],
    "errorLens.enabled": false
}
